
# Move focus to window with CMD + HJKL, Maybe change this to arrow?
cmd - h : yabai -m window --focus west
cmd - j : yabai -m window --focus south
cmd - l : yabai -m window --focus east
cmd - k : yabai -m window --focus north

# Move focus to display with CMD + a / ; | Maybe can remove this if only using
# one monitor
cmd - a : yabai -m display --focus east
cmd - 0x29 : yabai -m display --focus east

# Swap windows with arrow keys + CMD + Ctrl
cmd + ctrl - 0x7B : yabai -m window --swap west
cmd + ctrl - 0x7D : yabai -m window --swap south
cmd + ctrl - 0x7C : yabai -m window --swap east
cmd + ctrl - 0x7E : yabai -m window --swap north

# Move window to space with CMD + Shift + ALT + #
shift + ctrl - 1 : yabai -m window --space 1 --focus
shift + ctrl - 2 : yabai -m window --space 2
shift + ctrl - 3 : yabai -m window --space 3
shift + ctrl - 4 : yabai -m window --space 4
shift + ctrl - 5 : yabai -m window --space 5
shift + ctrl - 6 : yabai -m window --space 6
shift + ctrl - 7 : yabai -m window --space 7
shift + ctrl - 8 : yabai -m window --space 8
shift + ctrl - 9 : yabai -m window --space 9

# Cycle to next stack item
# CMD + ALT + Tab
cmd + alt - tab : yabai -m window --focus stack.next 2>/dev/null || yabai -m window --focus stack.first

shift + alt - p : yabai -m window --space prev
shift + alt - n : yabai -m window --space next

shift + alt -l : yabai -m window --resize right:20:0 --resize left:20:0
shift + alt -h : yabai -m window --resize right:-20:0 --resize left:-20:0
shift + alt -k : yabai -m window --resize top:0:-20 --resize bottom:0:-20
shift + alt -j : yabai -m window --resize top:0:20 --resize bottom:0:20

shift + alt - g : yabai -m window --opacity 0.1 && sleep $(yabai -m config window_opacity_duration) && yabai -m window --opacity 0.0


# toggle window float
shift + alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# maximize window
shift + alt - m : yabai -m window --toggle zoom-fullscreen

# balance out tree of windows (resize to occupy same area)
shift + alt - e : yabai -m space --balance

ctrl + alt - q : yabai --stop-service
ctrl + alt - s : yabai --start-service
ctrl + alt - r : yabai --restart-service

